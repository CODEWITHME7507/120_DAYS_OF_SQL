-- Day 4 - SQL Practice Questions (Intermediate)
CREATE TABLE Employees(
EmpID INT PRIMARY KEY,
EmpName VARCHAR(20) NOT NULL,
Department VARCHAR(20) NOT NULL,
Salary INT NOT NULL);

-- Q1. Display the total number of employees in each department using GROUP BY.

SELECT Department,COUNT(*) AS total_emp FROM Employees 
GROUP BY Department;


-- Q2. Display the average salary of each department.

SELECT Department , AVG(Salary) FROM Employees 
GROUP BY Department ;

-- Q3. Find the department with the highest average salary.

SELECT Department,AVG(Salary) AS HIGH_AVG FROM Employees 
GROUP BY Department ORDER BY HIGH_AVG DESC LIMIT 1;

-- Q4. Display only those departments where the total salary is greater than 200000 using HAVING.

SELECT Department,SUM(Salary) AS TOTAL_SAL FROM Employees 
GROUP BY Department HAVING TOTAL_SAL > 200000;

-- Q5. Find the maximum and minimum salary in each department.

SELECT Department , MAX(Salary) AS MAX_SAL , MIN(Salary) AS MIN_SAL FROM Employees
GROUP BY Department;

-- Q6. Count the number of employees in each department whose salary is greater than 50000.

SELECT Department , COUNT(*) AS CNE FROM Employees 
WHERE Salary > 50000 GROUP BY Department;

-- Q7. Display the total sales amount for each category from the Orders table using SUM(Quantity * Price).

SELECT Category ,SUM(Quantity*Price) AS total_sales FROM orders 
GROUP BY Category;

-- Q8. Display categories where the total sales amount is greater than 50000 using HAVING.

SELECT Category , SUM(Quantity*Price) AS Total_sales FROM orders
GROUP BY Category HAVING Total_sales > 50000;

-- Q9. Display the top 5 departments with the highest total salary.

SELECT Department , SUM(Salary) AS total_sal FROM Employees
GROUP BY Department ORDER BY total_sal DESC LIMIT 5;

-- Q10. Find the average, maximum, minimum, and total salary for all employees in a single query.

SELECT AVG(Salary) AS Average_sal ,MAX(Salary) AS Maximum_sal ,MIN(Salary) AS Minimum_sal ,SUM(Salary) AS total_sal FROM Employees;







