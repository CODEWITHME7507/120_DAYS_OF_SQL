'''Day 1 – SQL Basics Practice

1. Create a database named "CompanyDB".

CREATE DATABASE CompanyDB;

2. Use the "CompanyDB" database.

USE CompanyDB;

3. Create a table named "Employees1" with the following columns:
   
   - EmployeeID
   - Name
   - Age
   - Department
   - Salary
   
CREATE TABLE Employees1 (
    EmployeeID INT PRIMAY KEY,
    Name VARCHAR(50) NOT NULL,
    Age INT NOT NULL,
    Department VARCHAR(50) NOT NULL,
    Salary INT NOT NULL);
       

